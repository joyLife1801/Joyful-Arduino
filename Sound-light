#include <Adafruit_CircuitPlayground.h>

float value;

void setup() {
  Serial.begin(9600);
  CircuitPlayground.begin();
}

void loop() {
  CircuitPlayground.clearPixels();
  // Take 10 milliseconds of sound data to calculate
  value = CircuitPlayground.mic.soundPressureLevel(10);

  if (value > 75){
  CircuitPlayground.setPixelColor(0, 255, 0, 0);
  CircuitPlayground.setPixelColor(1, 255, 0, 255);
  CircuitPlayground.setPixelColor(2, 125, 0, 255);
  CircuitPlayground.setPixelColor(3, 0, 0, 255);
  CircuitPlayground.setPixelColor(4, 0, 128, 128);
  CircuitPlayground.setPixelColor(5, 0, 255, 255);
  CircuitPlayground.setPixelColor(6, 0, 255, 0);
  CircuitPlayground.setPixelColor(7, 125, 255, 0);
  CircuitPlayground.setPixelColor(8, 255, 255, 0);
  CircuitPlayground.setPixelColor(9, 255, 125, 0);
  }
  
  Serial.print("Sound Sensor SPL: ");
  Serial.println(value);

  delay(90);
}
